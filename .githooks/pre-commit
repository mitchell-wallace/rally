#!/usr/bin/env bash
# Pre-commit hook to verify formatting and run vet checks.
set -euo pipefail

echo "==> Running pre-commit checks..."

# Run go vet
echo "==> Running go vet ./..."
if ! go vet ./...; then
    echo "❌ go vet failed! Commit aborted." >&2
    exit 1
fi

# Check formatting
echo "==> Running go fmt check..."
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    echo "❌ The following files are not formatted correctly. Run 'go fmt ./...':" >&2
    echo "$unformatted" >&2
    exit 1
fi

echo "✅ Pre-commit checks passed!"
