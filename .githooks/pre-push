#!/usr/bin/env bash
# Pre-push hook to run full test suite before code is pushed to remote.
set -euo pipefail

if command -v just >/dev/null 2>&1; then
    just test
else
    echo "==> Running pre-push checks (fallback)..."
    # Run go test on the entire project
    echo "==> Running tests: go test -count=1 ./..."
    if ! go test -count=1 ./...; then
        echo "❌ Tests failed! Push aborted." >&2
        exit 1
    fi
    echo "✅ All checks passed! Pushing code..."
fi
